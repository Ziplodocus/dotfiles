{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "sticky_scroll": {
    "enabled": true,
  },
  "expand_excerpt_lines": 4,
  "double_click_in_multibuffer": "open",
  "which_key": {
    "enabled": true,
  },
  "colorize_brackets": true,
  "helix_mode": false,
  "completions": {
    "lsp_insert_mode": "replace",
  },
  "terminal": {
    "dock": "bottom",
    "font_family": "FiraCode Nerd Font",
  },
  "linked_edits": true,
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "prettier": {
    "allowed": true,
    "singleQuote": true,
  },
  "languages": {
    "HTML": {
      "hard_tabs": false,
      "formatter": "language_server",
    },
    "Go HTML Template": {},
    "PHP": {
      "inlay_hints": {
        "show_background": false,
        "enabled": true,
      },
      "indent_guides": {
        "background_coloring": "disabled",
        "coloring": "indent_aware",
      },
      "language_servers": [
        "intelephense",
        "emmet-language-server",
        "tailwindcss-language-server",
        "!phpactor",
        "!phptools",
      ],
      "formatter": "language_server",
    },
    "CSS": {
      "language_servers": [
        "vscode-css-language-server",
        "tailwindcss-language-server",
      ],
      "hard_tabs": null,
    },
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4",
    },
    "model_parameters": [],
  },
  "ui_font_family": ".ZedSans",
  "ui_font_size": 18.0,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "buffer_font_size": 16.0,
  "buffer_font_features": {
    "calt": true,
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "hide_hidden": false,
    "hide_root": true,
    "auto_fold_dirs": true,
    "starts_open": true,
    "indent_size": 18.0,
    "folder_icons": false,
    "entry_spacing": "standard",
    "dock": "right",
    "sort_mode": "directories_first",
    "drag_and_drop": true,
    "indent_guides": {
      "show": "never",
    },
    "sticky_scroll": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "file_icons": true,
    "hide_gitignore": false,
    "default_width": 240.0,
  },
  "ensure_final_newline_on_save": false,
  "show_completions_on_input": true,
  "diagnostics": {
    "inline": {
      "update_debounce_ms": 150,
    },
    "lsp_pull_diagnostics": {
      "debounce_ms": 100,
    },
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "format_on_save": "on",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "base_keymap": "VSCode",
  "vim_mode": false,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  "lsp": {
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore",
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "allFeatures": true,
          "features": "all",
        },
        "cargoFeatures": {
          "allFeatures": true,
        },
        "cargo-watch": {
          "arguments": "--all-features",
          "features": "all",
        },
        "procMacro": {
          "enable": true,
        },
      },
    },
    "intelephense": {
      "settings": {
        "format": {
          "enable": true,
          "braces": "k&r",
        },
        "stubs": [
          "apache",
          "bcmath",
          "bz2",
          "calendar",
          "com_dotnet",
          "Core",
          "ctype",
          "curl",
          "date",
          "dba",
          "dom",
          "enchant",
          "exif",
          "FFI",
          "fileinfo",
          "filter",
          "fpm",
          "ftp",
          "gd",
          "gettext",
          "gmp",
          "hash",
          "iconv",
          "imap",
          "intl",
          "json",
          "ldap",
          "libxml",
          "mbstring",
          "meta",
          "mysqli",
          "oci8",
          "odbc",
          "openssl",
          "pcntl",
          "pcre",
          "PDO",
          "pdo_ibm",
          "pdo_mysql",
          "pdo_pgsql",
          "pdo_sqlite",
          "pgsql",
          "Phar",
          "posix",
          "pspell",
          "readline",
          "Reflection",
          "session",
          "shmop",
          "SimpleXML",
          "snmp",
          "soap",
          "sockets",
          "sodium",
          "SPL",
          "sqlite3",
          "standard",
          "superglobals",
          "sysvmsg",
          "sysvsem",
          "sysvshm",
          "tidy",
          "tokenizer",
          "xml",
          "xmlreader",
          "xmlrpc",
          "xmlwriter",
          "xsl",
          "Zend OPcache",
          "zip",
          "zlib",
          "wordpress",
          "wordpress-globals",
        ],
      },
    },
    "phpactor": {
      "settings": {
        "enabled": false,
        "disabled": true,
      },
    },
  },
}
